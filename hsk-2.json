{"level":2,"label":"HSK 2","totalTerms":150,"terms":[{"word":"吧","pinyin":"ba","meaning":"đi, nhé, nhỉ (đứng cuối câu)","example":"请你帮我吧。","examplePinyin":"Qǐng nǐ bāng wǒ ba.","exampleMeaning":"Xin bạn giúp tôi nhé."},{"word":"白","pinyin":"bái","meaning":"trắng","example":"他的白色衬衫很漂亮。","examplePinyin":"Tā de báisè chènshān hěn piàoliang.","exampleMeaning":"Áo sơ mi trắng của anh ấy rất đẹp."},{"word":"百","pinyin":"bǎi","meaning":"trăm","example":"我们要买一百个苹果。","examplePinyin":"Wǒmen yào mǎi yī bǎi gè píngguǒ.","exampleMeaning":"Chúng tôi muốn mua một trăm quả táo."},{"word":"帮助","pinyin":"bāngzhù","meaning":"giúp đỡ","example":"请你帮忙翻译这篇文章。","examplePinyin":"Qǐng nǐ bāngmáng fānyì zhè piān wénzhāng.","exampleMeaning":"Xin bạn giúp dịch bài viết này."},{"word":"报纸","pinyin":"bàozhǐ","meaning":"báo","example":"我每天都看报纸。","examplePinyin":"Wǒ měitiān dōu kàn bàozhǐ.","exampleMeaning":"Tôi đọc báo mỗi ngày."},{"word":"比","pinyin":"bǐ","meaning":"so sánh","example":"我的家比你的家大。","examplePinyin":"Wǒ de jiā bǐ nǐ de jiā dà.","exampleMeaning":"Nhà của tôi lớn hơn nhà của bạn."},{"word":"别","pinyin":"bié","meaning":"đừng, khác biệt","example":"别忘带钥匙。","examplePinyin":"Bié wàng dài yàoshi.","exampleMeaning":"Đừng quên mang theo chìa khóa."},{"word":"长","pinyin":"cháng","meaning":"dài","example":"她的头发很长。","examplePinyin":"Tā de tóufǎ hěn cháng.","exampleMeaning":"Tóc của cô ấy rất dài."},{"word":"唱歌","pinyin":"chànggē","meaning":"hát","example":"我喜欢唱歌。","examplePinyin":"Wǒ xǐhuān chànggē.","exampleMeaning":"Tôi thích hát."},{"word":"出","pinyin":"chū","meaning":"ra ngoài","example":"我们出去玩吧。","examplePinyin":"Wǒmen chūqù wán ba.","exampleMeaning":"Chúng ta ra ngoài chơi đi."},{"word":"穿","pinyin":"chuān","meaning":"mặc","example":"你穿的衣服很漂亮。","examplePinyin":"Nǐ chuān de yīfú hěn piàoliang.","exampleMeaning":"Quần áo bạn mặc rất đẹp."},{"word":"船","pinyin":"chuán","meaning":"thuyền","example":"他坐在船上。","examplePinyin":"Tā zuò zài chuán shàng.","exampleMeaning":"Anh ấy ngồi trên thuyền."},{"word":"次","pinyin":"cì","meaning":"lần","example":"这是我第一次来这里。","examplePinyin":"Zhè shì wǒ dì yī cì lái zhèlǐ.","exampleMeaning":"Đây là lần đầu tiên tôi đến đây."},{"word":"从","pinyin":"cóng","meaning":"từ, theo","example":"他从早上工作到晚上。","examplePinyin":"Tā cóng zǎoshang gōngzuò dào wǎnshang.","exampleMeaning":"Anh ấy làm việc từ sáng đến tối."},{"word":"错","pinyin":"cuò","meaning":"sai","example":"他做错了一个题。","examplePinyin":"Tā zuò cuòle yīgè tí.","exampleMeaning":"Anh ấy đã làm sai một bài tập."},{"word":"打篮球","pinyin":"dǎ lánqiú","meaning":"chơi bóng rổ","example":"他打篮球打得很好。","examplePinyin":"Tā dǎ lánqiú dǎ de hěn hǎo.","exampleMeaning":"Anh ấy chơi bóng rổ rất giỏi."},{"word":"大家","pinyin":"dàjiā","meaning":"mọi người","example":"大家都很高兴。","examplePinyin":"Dàjiā dōu hěn gāoxìng.","exampleMeaning":"Mọi người đều rất vui."},{"word":"但是","pinyin":"dànshì","meaning":"nhưng","example":"我想去，但是没有时间。","examplePinyin":"Wǒ xiǎng qù, dànshì méiyǒu shíjiān.","exampleMeaning":"Tôi muốn đi, nhưng không có thời gian."},{"word":"到","pinyin":"dào","meaning":"đến","example":"我们今天到学校了。","examplePinyin":"Wǒmen jīntiān dào xuéxiào le.","exampleMeaning":"Hôm nay chúng tôi đã đến trường."},{"word":"得","pinyin":"děi","meaning":"phải, đạt được","example":"你得努力学习。","examplePinyin":"Nǐ děi nǔlì xuéxí.","exampleMeaning":"Bạn phải cố gắng học."},{"word":"等","pinyin":"děng","meaning":"đợi","example":"我们等你来。","examplePinyin":"Wǒmen děng nǐ lái.","exampleMeaning":"Chúng tôi đợi bạn đến."},{"word":"弟弟","pinyin":"dìdì","meaning":"em trai","example":"弟弟在玩玩具。","examplePinyin":"Dìdì zài wán wánjù.","exampleMeaning":"Em trai đang chơi đồ chơi."},{"word":"第一","pinyin":"dì yī","meaning":"đầu tiên","example":"他是第一名。","examplePinyin":"Tā shì dì yī míng.","exampleMeaning":"Anh ấy là người đứng đầu."},{"word":"懂","pinyin":"dǒng","meaning":"hiểu","example":"我不懂这个问题。","examplePinyin":"Wǒ bù dǒng zhège wèntí.","exampleMeaning":"Tôi không hiểu vấn đề này."},{"word":"对","pinyin":"duì","meaning":"đúng, đối với","example":"你对我很好。","examplePinyin":"Nǐ duì wǒ hěn hǎo.","exampleMeaning":"Bạn đối xử tốt với tôi."},{"word":"房间","pinyin":"fángjiān","meaning":"phòng","example":"房间里很安静。","examplePinyin":"Fángjiān lǐ hěn ānjìng.","exampleMeaning":"Trong phòng rất yên tĩnh."},{"word":"非常","pinyin":"fēicháng","meaning":"rất, cực kỳ","example":"这道菜非常好吃。","examplePinyin":"Zhè dào cài fēicháng hǎochī.","exampleMeaning":"Món ăn này rất ngon."},{"word":"服务员","pinyin":"fúwùyuán","meaning":"nhân viên phục vụ","example":"服务员请帮忙。","examplePinyin":"Fúwùyuán qǐng bāngmáng.","exampleMeaning":"Nhân viên phục vụ, xin giúp đỡ."},{"word":"高","pinyin":"gāo","meaning":"cao","example":"他很高。","examplePinyin":"Tā hěn gāo.","exampleMeaning":"Anh ấy rất cao."},{"word":"告诉","pinyin":"gàosù","meaning":"nói cho, thông báo","example":"请告诉我答案。","examplePinyin":"Qǐng gàosù wǒ dá'àn.","exampleMeaning":"Xin cho tôi biết đáp án."},{"word":"哥哥","pinyin":"gēge","meaning":"anh trai","example":"哥哥在家里。","examplePinyin":"Gēge zài jiālǐ.","exampleMeaning":"Anh trai đang ở nhà."},{"word":"给","pinyin":"gěi","meaning":"đưa cho, cho","example":"请给我一本书。","examplePinyin":"Qǐng gěi wǒ yī běn shū.","exampleMeaning":"Xin hãy đưa cho tôi một cuốn sách."},{"word":"公共汽车","pinyin":"gōnggòng qìchē","meaning":"xe buýt","example":"公共汽车很方便。","examplePinyin":"Gōnggòng qìchē hěn fāngbiàn.","exampleMeaning":"Xe buýt rất tiện lợi."},{"word":"公斤","pinyin":"gōngjīn","meaning":"kilogram (kg)","example":"这个包十公斤。","examplePinyin":"Zhège bāo shí gōngjīn.","exampleMeaning":"Cái túi này mười kilogram."},{"word":"公司","pinyin":"gōngsī","meaning":"công ty","example":"我在公司工作。","examplePinyin":"Wǒ zài gōngsī gōngzuò.","exampleMeaning":"Tôi làm việc ở công ty."},{"word":"贵","pinyin":"guì","meaning":"đắt, quý","example":"这件衣服很贵。","examplePinyin":"Zhè jiàn yīfú hěn guì.","exampleMeaning":"Cái áo này rất đắt."},{"word":"过","pinyin":"guò","meaning":"qua, đi qua","example":"请过安检门。","examplePinyin":"Qǐng guò ānjiǎn mén.\\","exampleMeaning":"Mời đi qua cửa an ninh."},{"word":"还","pinyin":"hái","meaning":"vẫn, còn","example":"我还想要一杯水。","examplePinyin":"Wǒ hái xiǎng yào yī bēi shuǐ.","exampleMeaning":"Tôi còn muốn một cốc nước."},{"word":"孩子","pinyin":"háizi","meaning":"trẻ con","example":"孩子们都在玩。","examplePinyin":"Háizimen dōu zài wán.","exampleMeaning":"Những đứa trẻ đang chơi."},{"word":"好吃","pinyin":"hǎochī","meaning":"ngon","example":"这道菜很好吃。","examplePinyin":"Zhè dào cài hěn hǎo chī.","exampleMeaning":"Món ăn này rất ngon."},{"word":"号","pinyin":"hào","meaning":"số (như số điện thoại, số nhà)","example":"你的手机号是多少？","examplePinyin":"Nǐ de shǒujī hào shì duōshǎo?","exampleMeaning":"Số điện thoại của bạn là bao nhiêu?"},{"word":"黑","pinyin":"hēi","meaning":"đen","example":"我的车是黑色的。","examplePinyin":"Wǒ de chē shì hēisè de.","exampleMeaning":"Xe của tôi màu đen."},{"word":"红","pinyin":"hóng","meaning":"đỏ","example":"她喜欢红色的衣服。","examplePinyin":"Tā xǐhuān hóngsè de yīfú.","exampleMeaning":"Cô ấy thích quần áo màu đỏ."},{"word":"欢迎","pinyin":"huānyíng","meaning":"hoan nghênh, chào mừng","example":"欢迎你来我家。","examplePinyin":"Huānyíng nǐ lái wǒ jiā.","exampleMeaning":"Chào mừng bạn đến nhà tôi."},{"word":"回答","pinyin":"huídá","meaning":"trả lời","example":"请回答我的问题。","examplePinyin":"Qǐng huídá wǒ de wèntí.","exampleMeaning":"Xin trả lời câu hỏi của tôi."},{"word":"机场","pinyin":"jīchǎng","meaning":"sân bay","example":"机场离这里很近。","examplePinyin":"Jīchǎng lí zhèlǐ hěn jìn.","exampleMeaning":"Sân bay gần đây."},{"word":"鸡蛋","pinyin":"jīdàn","meaning":"trứng gà","example":"我喜欢吃鸡蛋。","examplePinyin":"Wǒ xǐhuān chī jīdàn.","exampleMeaning":"Tôi thích ăn trứng."},{"word":"件","pinyin":"jiàn","meaning":"cái (dùng cho sự việc, quần áo)","example":"这件衣服很好看。","examplePinyin":"Zhè jiàn yīfú hěn hǎokàn.","exampleMeaning":"Cái áo này rất đẹp."},{"word":"教室","pinyin":"jiàoshì","meaning":"lớp học","example":"学生们在教室里学习。","examplePinyin":"Xuéshēngmen zài jiàoshì lǐ xuéxí.","exampleMeaning":"Học sinh đang học trong lớp học."},{"word":"姐姐","pinyin":"jiějie","meaning":"chị gái","example":"姐姐比我大三岁。","examplePinyin":"Jiějiě bǐ wǒ dà sān suì.","exampleMeaning":"Chị gái lớn hơn tôi ba tuổi."},{"word":"介绍","pinyin":"jièshào","meaning":"giới thiệu","example":"请介绍一下你自己。","examplePinyin":"Qǐng jièshào yīxià nǐ zìjǐ.","exampleMeaning":"Xin hãy giới thiệu về bản thân."},{"word":"进","pinyin":"jìn","meaning":"vào","example":"请进，别客气。","examplePinyin":"Qǐng jìn, bié kèqì.","exampleMeaning":"Mời vào, đừng khách sáo."},{"word":"近","pinyin":"jìn","meaning":"gần","example":"学校离我家很近。","examplePinyin":"Xuéxiào lí wǒ jiā hěn jìn.","exampleMeaning":"Trường học gần nhà tôi."},{"word":"就","pinyin":"jiù","meaning":"thì, ngay","example":"他就住在我家旁边。","examplePinyin":"Tā jiù zhù zài wǒ jiā pángbiān.","exampleMeaning":"Anh ấy sống ngay cạnh nhà tôi."},{"word":"觉得","pinyin":"juéde","meaning":"cảm thấy","example":"我觉得今天很热。","examplePinyin":"Wǒ juéde jīntiān hěn rè.","exampleMeaning":"Tôi cảm thấy hôm nay rất nóng."},{"word":"咖啡","pinyin":"kāfēi","meaning":"cà phê","example":"我每天早上喝咖啡。","examplePinyin":"Wǒ měitiān zǎoshang hē kāfēi.","exampleMeaning":"Tôi uống cà phê mỗi sáng."},{"word":"开始","pinyin":"kāishǐ","meaning":"bắt đầu","example":"我们现在开始上课。","examplePinyin":"Wǒmen xiànzài kāishǐ shàngkè.","exampleMeaning":"Bây giờ chúng ta bắt đầu học."},{"word":"考试","pinyin":"kǎoshì","meaning":"thi","example":"我准备好考试了。","examplePinyin":"Wǒ zhǔnbèi hǎo kǎoshì le.","exampleMeaning":"Tôi đã chuẩn bị sẵn sàng cho kỳ thi."},{"word":"可能","pinyin":"kěnéng","meaning":"có thể","example":"可能会下雨。","examplePinyin":"Kěnéng huì xiàyǔ.","exampleMeaning":"Có thể sẽ mưa."},{"word":"可以","pinyin":"kěyǐ","meaning":"có thể","example":"你可以坐在这里。","examplePinyin":"Nǐ kěyǐ zuò zài zhèlǐ.","exampleMeaning":"Bạn có thể ngồi ở đây."},{"word":"课","pinyin":"kè","meaning":"bài học","example":"我们今天有三节课。","examplePinyin":"Wǒmen jīntiān yǒu sān jié kè.","exampleMeaning":"Hôm nay chúng ta có ba tiết học."},{"word":"快","pinyin":"kuài","meaning":"nhanh","example":"他跑得很快。","examplePinyin":"Tā pǎo de hěn kuài.","exampleMeaning":"Anh ấy chạy rất nhanh."},{"word":"快乐","pinyin":"kuàilè","meaning":"vui vẻ","example":"祝你生日快乐。","examplePinyin":"Zhù nǐ shēngrì kuàilè.","exampleMeaning":"Chúc bạn sinh nhật vui vẻ."},{"word":"累","pinyin":"lèi","meaning":"mệt","example":"我累了，想休息一下。","examplePinyin":"Wǒ lèile, xiǎng xiūxí yīxià.","exampleMeaning":"Tôi mệt rồi, muốn nghỉ ngơi một chút."},{"word":"离","pinyin":"lí","meaning":"cách (khoảng cách), rời","example":"学校离我家不远。","examplePinyin":"Xuéxiào lí wǒ jiā bù yuǎn.","exampleMeaning":"Trường học không xa nhà tôi."},{"word":"两","pinyin":"liǎng","meaning":"hai (khi đếm số lượng)","example":"我有两个弟弟。","examplePinyin":"Wǒ yǒu liǎng gè dìdì.","exampleMeaning":"Tôi có hai em trai."},{"word":"路","pinyin":"lù","meaning":"đường","example":"这条路很长。","examplePinyin":"Zhè tiáo lù hěn cháng.","exampleMeaning":"Con đường này rất dài."},{"word":"旅游","pinyin":"lǚyóu","meaning":"du lịch","example":"我喜欢旅游。","examplePinyin":"Wǒ xǐhuān lǚyóu.","exampleMeaning":"Tôi thích du lịch."},{"word":"卖","pinyin":"mài","meaning":"bán","example":"他在商店里卖东西。","examplePinyin":"Tā zài shāngdiàn lǐ mài dōngxī.","exampleMeaning":"Anh ấy bán hàng trong cửa hàng."},{"word":"慢","pinyin":"màn","meaning":"chậm","example":"他走得很慢。","examplePinyin":"Tā zǒu de hěn màn.","exampleMeaning":"Anh ấy đi rất chậm."},{"word":"忙","pinyin":"máng","meaning":"bận","example":"我今天很忙。","examplePinyin":"Wǒ jīntiān hěn máng.","exampleMeaning":"Hôm nay tôi rất bận."},{"word":"每","pinyin":"měi","meaning":"mỗi","example":"每个人都有机会。","examplePinyin":"Měi gèrén dōu yǒu jīhuì.","exampleMeaning":"Mỗi người đều có cơ hội."},{"word":"妹妹","pinyin":"mèimei","meaning":"em gái","example":"妹妹在唱歌。","examplePinyin":"Mèimei zài chànggē.","exampleMeaning":"Em gái đang hát."},{"word":"门","pinyin":"mén","meaning":"cửa","example":"他站在门口。","examplePinyin":"Tā zhàn zài ménkǒu.","exampleMeaning":"Anh ấy đứng ở cửa."},{"word":"男人","pinyin":"nánrén","meaning":"đàn ông","example":"那个男人很高。","examplePinyin":"Nàgè nánrén hěn gāo.","exampleMeaning":"Người đàn ông đó rất cao."},{"word":"您","pinyin":"nín","meaning":"Ông, ngài","example":"您好，请进。","examplePinyin":"Nín hǎo, qǐng jìn.","exampleMeaning":"Xin chào, mời vào."},{"word":"牛奶","pinyin":"niúnǎi","meaning":"sữa bò","example":"我每天早上喝牛奶。","examplePinyin":"Wǒ měitiān zǎoshang hē niúnǎi.","exampleMeaning":"Tôi uống sữa mỗi sáng."},{"word":"女人","pinyin":"nǚrén","meaning":"phụ nữ","example":"那个女人是我妈妈。","examplePinyin":"Nàgè nǚrén shì wǒ māma.","exampleMeaning":"Người phụ nữ đó là mẹ tôi."},{"word":"旁边","pinyin":"pángbiān","meaning":"bên cạnh","example":"学校在我家旁边。","examplePinyin":"Xuéxiào zài wǒ jiā pángbiān.","exampleMeaning":"Trường học ở cạnh nhà tôi."},{"word":"跑步","pinyin":"pǎobù","meaning":"chạy bộ","example":"我每天早上跑步。","examplePinyin":"Wǒ měitiān zǎoshang pǎobù.","exampleMeaning":"Tôi chạy bộ mỗi sáng."},{"word":"便宜","pinyin":"piányí","meaning":"rẻ","example":"这件衣服很便宜。","examplePinyin":"Zhè jiàn yīfú hěn piányí.","exampleMeaning":"Cái áo này rất rẻ."},{"word":"票","pinyin":"piào","meaning":"vé","example":"我买了两张电影票。","examplePinyin":"Wǒ mǎile liǎng zhāng diànyǐng piào.","exampleMeaning":"Tôi đã mua hai vé xem phim."},{"word":"妻子","pinyin":"qīzi","meaning":"vợ","example":"这是我的妻子。","examplePinyin":"Zhè shì wǒ de qīzi.","exampleMeaning":"Đây là vợ tôi."},{"word":"起床","pinyin":"qǐchuáng","meaning":"dậy (rời khỏi giường)","example":"我每天六点起床。","examplePinyin":"Wǒ měitiān liù diǎn qǐchuáng.","exampleMeaning":"Tôi thức dậy lúc sáu giờ mỗi ngày."},{"word":"千","pinyin":"qiān","meaning":"nghìn","example":"我有一千块钱。","examplePinyin":"Wǒ yǒu yīqiān kuài qián.","exampleMeaning":"Tôi có một ngàn đồng."},{"word":"晴","pinyin":"qíng","meaning":"nắng, quang đãng","example":"今天是晴天。","examplePinyin":"Jīntiān shì qíngtiān.","exampleMeaning":"Hôm nay trời nắng."},{"word":"去年","pinyin":"qùnián","meaning":"năm ngoái","example":"我去年去了中国。","examplePinyin":"Wǒ qùnián qùle zhōngguó.","exampleMeaning":"Năm ngoái tôi đã đi Trung Quốc."},{"word":"让","pinyin":"ràng","meaning":"để, làm cho, nhường","example":"请让他进来。","examplePinyin":"Qǐng ràng tā jìnlái.","exampleMeaning":"Xin hãy để anh ấy vào."},{"word":"上班","pinyin":"shàngbān","meaning":"đi làm","example":"我每天八点上班。","examplePinyin":"Wǒ měitiān bā diǎn shàngbān.","exampleMeaning":"Tôi đi làm lúc tám giờ mỗi ngày."},{"word":"身体","pinyin":"shēntǐ","meaning":"cơ thể","example":"你的身体怎么样？","examplePinyin":"Nǐ de shēntǐ zěnme yàng?","exampleMeaning":"Sức khỏe của bạn thế nào?"},{"word":"生病","pinyin":"shēngbìng","meaning":"bị bệnh","example":"他生病了，不能来上课。","examplePinyin":"Tā shēngbìng le, bùnéng lái shàngkè.","exampleMeaning":"Anh ấy bị ốm, không thể đến lớp."},{"word":"生日","pinyin":"shēngrì","meaning":"sinh nhật","example":"今天是我的生日。","examplePinyin":"Jīntiān shì wǒ de shēngrì.","exampleMeaning":"Hôm nay là sinh nhật của tôi."},{"word":"时间","pinyin":"shíjiān","meaning":"thời gian","example":"现在我没有时间。","examplePinyin":"Xiànzài wǒ méiyǒu shíjiān.","exampleMeaning":"Bây giờ tôi không có thời gian."},{"word":"事情","pinyin":"shìqíng","meaning":"việc","example":"你在做什么事情？","examplePinyin":"Nǐ zài zuò shénme shìqíng?","exampleMeaning":"Bạn đang làm việc gì vậy?"},{"word":"手表","pinyin":"shǒubiǎo","meaning":"đồng hồ","example":"这块手表很贵。","examplePinyin":"Zhè kuài shǒubiǎo hěn guì.","exampleMeaning":"Chiếc đồng hồ này rất đắt."},{"word":"手机","pinyin":"shǒujī","meaning":"điện thoại di động","example":"我的手机没电了。","examplePinyin":"Wǒ de shǒujī méi diàn le.","exampleMeaning":"Điện thoại của tôi hết pin rồi."},{"word":"送","pinyin":"sòng","meaning":"tặng","example":"我送你一本书。","examplePinyin":"Wǒ sòng nǐ yī běn shū.","exampleMeaning":"Tôi tặng bạn một quyển sách."},{"word":"所以","pinyin":"suǒyǐ","meaning":"vì vậy","example":"他很累，所以休息了。","examplePinyin":"Tā hěn lèi, suǒyǐ xiūxí le.","exampleMeaning":"Anh ấy rất mệt, nên đã nghỉ ngơi rồi."},{"word":"它","pinyin":"tā","meaning":"nó (cho vật, động vật)","example":"它是一只可爱的小猫。","examplePinyin":"Tā shì yī zhī kě'ài de xiǎo māo.","exampleMeaning":"Nó là một chú mèo đáng yêu."},{"word":"踢足球","pinyin":"tī zúqiú","meaning":"đá bóng","example":"我们一起踢足球吧。","examplePinyin":"Wǒmen yīqǐ tī zúqiú ba.","exampleMeaning":"Chúng ta cùng chơi đá bóng nhé."},{"word":"题","pinyin":"tí","meaning":"câu hỏi, đề bài","example":"这道题很难。","examplePinyin":"Zhè dào tí hěn nán.","exampleMeaning":"Câu hỏi này rất khó."},{"word":"跳舞","pinyin":"tiàowǔ","meaning":"nhảy múa","example":"我喜欢跳舞。","examplePinyin":"Wǒ xǐhuān tiàowǔ.","exampleMeaning":"Tôi thích nhảy múa."},{"word":"外","pinyin":"wài","meaning":"ngoài","example":"他在外面等你。","examplePinyin":"Tā zài wàimiàn děng nǐ.","exampleMeaning":"Anh ấy đang đợi bạn ở bên ngoài."},{"word":"玩","pinyin":"wán","meaning":"chơi","example":"小孩子们在玩游戏。","examplePinyin":"Xiǎo háizimen zài wán yóuxì.","exampleMeaning":"Các em nhỏ đang chơi trò chơi."},{"word":"完","pinyin":"wán","meaning":"xong, hoàn thành","example":"我已经做完了作业。","examplePinyin":"Wǒ yǐjīng zuò wán le zuòyè.","exampleMeaning":"Tôi đã làm xong bài tập."},{"word":"晚上","pinyin":"wǎnshàng","meaning":"buổi tối","example":"我晚上九点睡觉。","examplePinyin":"Wǒ wǎnshàng jiǔ diǎn shuìjiào.","exampleMeaning":"Tôi đi ngủ lúc chín giờ tối."},{"word":"为什么","pinyin":"wèishénme","meaning":"tại sao","example":"你为什么不来？","examplePinyin":"Nǐ wèishéme bù lái?","exampleMeaning":"Tại sao bạn không đến?"},{"word":"问","pinyin":"wèn","meaning":"hỏi","example":"请问你叫什么名字？","examplePinyin":"Qǐng wèn nǐ jiào shénme míngzì?","exampleMeaning":"Xin hỏi bạn tên là gì?"},{"word":"问题","pinyin":"wèntí","meaning":"vấn đề","example":"这个问题很重要。","examplePinyin":"Zhège wèntí hěn zhòngyào.","exampleMeaning":"Vấn đề này rất quan trọng."},{"word":"西瓜","pinyin":"xīguā","meaning":"dưa hấu","example":"我喜欢吃西瓜。","examplePinyin":"Wǒ xǐhuān chī xīguā.","exampleMeaning":"Tôi thích ăn dưa hấu."},{"word":"希望","pinyin":"xīwàng","meaning":"hy vọng","example":"我希望你能来。","examplePinyin":"Wǒ xīwàng nǐ néng lái.","exampleMeaning":"Tôi hy vọng bạn có thể đến."},{"word":"洗","pinyin":"xǐ","meaning":"rửa","example":"请洗手。","examplePinyin":"Qǐng xǐ shǒu.","exampleMeaning":"Xin rửa tay."},{"word":"向","pinyin":"xiàng","meaning":"hướng về, đối với","example":"向左走。","examplePinyin":"Xiàng zuǒ zǒu.","exampleMeaning":"Đi về phía bên trái."},{"word":"小时","pinyin":"xiǎoshí","meaning":"tiếng đồng hồ","example":"我每天学习一个小时。","examplePinyin":"Wǒ měitiān xuéxí yī gè xiǎoshí.","exampleMeaning":"Tôi học một tiếng mỗi ngày."},{"word":"笑","pinyin":"xiào","meaning":"cười","example":"他在笑什么？","examplePinyin":"Tā zài xiào shénme?","exampleMeaning":"Anh ấy đang cười gì vậy?"},{"word":"新","pinyin":"xīn","meaning":"mới","example":"我有一个新手机。","examplePinyin":"Wǒ yǒu yī gè xīn shǒujī.","exampleMeaning":"Tôi có một chiếc điện thoại mới."},{"word":"姓","pinyin":"xìng","meaning":"họ","example":"你姓什么？","examplePinyin":"Nǐ xìng shénme?","exampleMeaning":"Họ của bạn là gì?"},{"word":"休息","pinyin":"xiūxi","meaning":"nghỉ ngơi","example":"我累了，需要休息。","examplePinyin":"Wǒ lèile, xūyào xiūxí.","exampleMeaning":"Tôi mệt rồi, cần nghỉ ngơi."},{"word":"雪","pinyin":"xuě","meaning":"tuyết","example":"明天会下雪。","examplePinyin":"Míngtiān huì xià xuě.","exampleMeaning":"Ngày mai sẽ có tuyết rơi."},{"word":"颜色","pinyin":"yánsè","meaning":"màu sắc","example":"你喜欢什么颜色？","examplePinyin":"Nǐ xǐhuān shénme yánsè?","exampleMeaning":"Bạn thích màu gì?"},{"word":"眼睛","pinyin":"yǎnjing","meaning":"mắt","example":"他的眼睛很大。","examplePinyin":"Tā de yǎnjīng hěn dà.","exampleMeaning":"Mắt của anh ấy rất to."},{"word":"羊肉","pinyin":"yángròu","meaning":"thịt cừu","example":"我喜欢吃羊肉。","examplePinyin":"Wǒ xǐhuān chī yángròu.","exampleMeaning":"Tôi thích ăn thịt cừu."},{"word":"要","pinyin":"yào","meaning":"muốn, cần","example":"我要一杯水。","examplePinyin":"Wǒ yào yī bēi shuǐ.","exampleMeaning":"Tôi muốn một cốc nước."},{"word":"药","pinyin":"yào","meaning":"thuốc","example":"我生病了，要吃药。","examplePinyin":"Wǒ shēngbìng le, yào chī yào.","exampleMeaning":"Tôi bị ốm, cần uống thuốc."},{"word":"也","pinyin":"yě","meaning":"cũng","example":"他也喜欢游泳。","examplePinyin":"Tā yě xǐhuān yóuyǒng.","exampleMeaning":"Anh ấy cũng thích bơi lội."},{"word":"已经","pinyin":"yǐjīng","meaning":"đã","example":"我已经吃过饭了。","examplePinyin":"Wǒ yǐjīng chī guò fàn le.","exampleMeaning":"Tôi đã ăn cơm rồi."},{"word":"一起","pinyin":"yìqǐ","meaning":"cùng nhau","example":"我们一起去看电影吧。","examplePinyin":"Wǒmen yīqǐ qù kàn diànyǐng ba.","exampleMeaning":"Chúng ta cùng đi xem phim nhé."},{"word":"意思","pinyin":"yìsi","meaning":"ý nghĩa","example":"这是什么意思？","examplePinyin":"Zhè shì shénme yìsi?","exampleMeaning":"Điều này có nghĩa là gì?"},{"word":"阴","pinyin":"yīn","meaning":"âm u, trời nhiều mây","example":"今天是阴天。","examplePinyin":"Jīntiān shì yīntiān.","exampleMeaning":"Hôm nay là ngày trời âm u."},{"word":"因为","pinyin":"yīnwèi","meaning":"vì","example":"因为下雨，我不去跑步。","examplePinyin":"Yīnwèi xiàyǔ, wǒ bú qù pǎobù.","exampleMeaning":"Vì trời mưa, tôi không đi chạy bộ."},{"word":"游泳","pinyin":"yóuyǒng","meaning":"bơi","example":"我喜欢游泳。","examplePinyin":"Wǒ xǐhuān yóuyǒng.","exampleMeaning":"Tôi thích bơi lội."},{"word":"右边","pinyin":"yòubiān","meaning":"bên phải","example":"他坐在我右边。","examplePinyin":"Tā zuò zài wǒ yòubiān.","exampleMeaning":"Anh ấy ngồi bên phải tôi."},{"word":"鱼","pinyin":"yú","meaning":"cá","example":"我们晚饭吃鱼。","examplePinyin":"Wǒmen wǎnfàn chī yú.","exampleMeaning":"Chúng tôi ăn cá vào bữa tối."},{"word":"元","pinyin":"yuán","meaning":"Đồng (đơn vị tiền tệ)","example":"这本书要十元。","examplePinyin":"Zhè běn shū yào shí yuán.","exampleMeaning":"Quyển sách này giá mười đồng."},{"word":"远","pinyin":"yuǎn","meaning":"xa","example":"他家离学校很远。","examplePinyin":"Tā jiā lí xuéxiào hěn yuǎn.","exampleMeaning":"Nhà anh ấy cách xa trường học."},{"word":"运动","pinyin":"yùndòng","meaning":"vận","example":"我每天都运动。","examplePinyin":"Wǒ měitiān dōu yùndòng.","exampleMeaning":"Tôi tập thể dục mỗi ngày."},{"word":"再","pinyin":"zài","meaning":"lại","example":"请再说一遍。","examplePinyin":"Qǐng zài shuō yī biàn.","exampleMeaning":"Xin hãy nói lại một lần nữa."},{"word":"早上","pinyin":"zǎoshàng","meaning":"buổi sáng","example":"我每天早上六点起床。","examplePinyin":"Wǒ měitiān zǎoshang liù diǎn qǐchuáng.","exampleMeaning":"Tôi dậy lúc sáu giờ sáng mỗi ngày."},{"word":"张","pinyin":"zhāng","meaning":"tờ, bức (dùng cho vật phẳng, giấy, tranh, bàn)","example":"这是一张照片。","examplePinyin":"Zhè shì yī zhāng zhàopiàn.","exampleMeaning":"Đây là một tấm ảnh."},{"word":"丈夫","pinyin":"zhàngfu","meaning":"chồng","example":"这是我的丈夫。","examplePinyin":"Zhè shì wǒ de zhàngfu.","exampleMeaning":"Đây là chồng tôi."},{"word":"找","pinyin":"zhǎo","meaning":"tìm","example":"我在找我的钥匙。","examplePinyin":"Wǒ zài zhǎo wǒ de yàoshi.","exampleMeaning":"Tôi đang tìm chìa khóa của mình."},{"word":"着","pinyin":"zhe","meaning":"đang (dùng để chỉ trạng thái hiện tại)","example":"他在吃着饭呢。","examplePinyin":"Tā zài chī zhe fàn ne.","exampleMeaning":"Anh ấy đang ăn cơm."},{"word":"真","pinyin":"zhēn","meaning":"thật","example":"这个苹果真好吃。","examplePinyin":"Zhège píngguǒ zhēn hào chī.","exampleMeaning":"Quả táo này thật ngon."},{"word":"正在","pinyin":"zhèngzài","meaning":"đang","example":"妈妈正在打电话。","examplePinyin":"Māma zhèngzài dǎ diànhuà.","exampleMeaning":"Mẹ đang gọi điện thoại.\n"},{"word":"知道","pinyin":"zhīdào","meaning":"biết","example":"我知道他是谁。","examplePinyin":"Wǒ zhīdào tā shì shéi.","exampleMeaning":"Tôi biết anh ấy là ai."},{"word":"准备","pinyin":"zhǔnbèi","meaning":"chuẩn bị","example":"我正在准备考试。","examplePinyin":"Wǒ zhèngzài zhǔnbèi kǎoshì.","exampleMeaning":"Tôi đang chuẩn bị cho kỳ thi."},{"word":"自行车","pinyin":"zìxíngchē","meaning":"xe đạp","example":"他骑自行车去上班。","examplePinyin":"Tā qí zìxíngchē qù shàngbān.","exampleMeaning":"Anh ấy đi làm bằng xe đạp."},{"word":"走","pinyin":"zǒu","meaning":"đi","example":"我们一起走吧。","examplePinyin":"Wǒmen yīqǐ zǒu ba.","exampleMeaning":"Chúng ta cùng đi nhé."},{"word":"最","pinyin":"zuì","meaning":"nhất (so sánh nhất)","example":"这是我最喜欢的书。","examplePinyin":"Zhè shì wǒ zuì xǐhuān de shū.","exampleMeaning":"Đây là cuốn sách tôi thích nhất."},{"word":"左边","pinyin":"zuǒbiān","meaning":"bên trái","example":"他坐在我左边。","examplePinyin":"Tā zuò zài wǒ zuǒbiān.","exampleMeaning":"Anh ấy ngồi bên trái tôi."}]}