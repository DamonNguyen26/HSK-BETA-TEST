{"level":1,"label":"HSK 1","totalTerms":149,"terms":[{"word":"爱","pinyin":"ài","meaning":"yêu","example":"我爱你。","examplePinyin":"Wǒ ài nǐ.","exampleMeaning":"Tôi yêu bạn."},{"word":"八","pinyin":"bā","meaning":"tám/ 8","example":"他有八个苹果。","examplePinyin":"Tā yǒu bā ge píngguǒ.","exampleMeaning":"Anh ấy có tám quả táo."},{"word":"爸爸","pinyin":"bàba","meaning":"bố","example":"我的爸爸很高。","examplePinyin":"Wǒ de bàba hěn gāo.","exampleMeaning":"Bố của tôi rất cao."},{"word":"杯子","pinyin":"bēizi","meaning":"cốc/ca/ly","example":"这是我的杯子。","examplePinyin":"Zhè shì wǒ de bēizi.","exampleMeaning":"Đây là cốc của tôi."},{"word":"北京","pinyin":"Běijīng","meaning":"Bắc Kinh","example":"北京很大。","examplePinyin":"Běijīng hěn dà.","exampleMeaning":"Bắc Kinh thì lớn."},{"word":"本","pinyin":"běn","meaning":"cuốn (dùng cho sách) / quyển","example":"这本书很有趣。","examplePinyin":"Zhè běn shū hěn yǒuqù.","exampleMeaning":"Quyển sách này rất thú vị."},{"word":"不客气","pinyin":"bú kèqì","meaning":"không có gì (đáp lại lời cảm ơn)","example":"不客气。","examplePinyin":"bú kèqì.","exampleMeaning":"Không có gì."},{"word":"不","pinyin":"bù","meaning":"không","example":"他不喜欢吃鱼。","examplePinyin":"Tā bù xǐhuān chī yú.","exampleMeaning":"Anh ấy không thích ăn cá."},{"word":"菜","pinyin":"cài","meaning":"món ăn, rau củ","example":"我喜欢吃菜。","examplePinyin":"Wǒ xǐhuān chī cài.","exampleMeaning":"Tôi thích ăn rau."},{"word":"茶","pinyin":"chá","meaning":"trà","example":"我喝茶。","examplePinyin":"Wǒ hē chá.","exampleMeaning":"Tôi uống trà."},{"word":"吃","pinyin":"chī","meaning":"ăn","example":"我吃苹果。","examplePinyin":"Wǒ chī píngguǒ.","exampleMeaning":"Tôi ăn táo."},{"word":"出租车","pinyin":"chūzūchē","meaning":"taxi","example":"我坐出租车。","examplePinyin":"Wǒ zuò chūzūchē.","exampleMeaning":"Tôi đi taxi."},{"word":"打电话","pinyin":"dǎ diànhuà","meaning":"gọi điện thoại","example":"她给我打电话。","examplePinyin":"Tā gěi wǒ dǎ diànhuà.","exampleMeaning":"Cô ấy gọi điện cho tôi."},{"word":"大","pinyin":"dà","meaning":"lớn, to","example":"这件衣服很大。","examplePinyin":"Zhè jiàn yīfú hěn dà.","exampleMeaning":"Cái áo này rất to."},{"word":"的","pinyin":"de","meaning":"của (thuộc tính)","example":"这是我的书。","examplePinyin":"Zhè shì wǒ de shū.","exampleMeaning":"Đây là sách của tôi."},{"word":"点","pinyin":"diǎn","meaning":"giờ (trong thời gian)","example":"现在是三点。","examplePinyin":"Xiànzài shì sān diǎn?","exampleMeaning":"Bây giờ là mấy giờ?"},{"word":"电脑","pinyin":"diànnǎo","meaning":"máy tính","example":"我用电脑。","examplePinyin":"Wǒ yòng diànnǎo.","exampleMeaning":"Tôi dùng máy tính."},{"word":"电视","pinyin":"diànshì","meaning":"ti vi","example":"电视很大。","examplePinyin":"Diànshì hěn dà.","exampleMeaning":"Tivi thì lớn."},{"word":"电影","pinyin":"diànyǐng","meaning":"phim","example":"我喜欢看电影。","examplePinyin":"Wǒ xǐhuān kàn diànyǐng.","exampleMeaning":"Tôi thích xem phim."},{"word":"东西","pinyin":"dōngxī","meaning":"đồ vật, thứ","example":"这是什么东西？","examplePinyin":"Zhè shì shénme dōngxī?","exampleMeaning":"Đây là cái gì?"},{"word":"都","pinyin":"dōu","meaning":"đều","example":"我们都去学校。","examplePinyin":"Wǒmen dōu qù xuéxiào.","exampleMeaning":"Chúng tôi đều đi đến trường."},{"word":"读","pinyin":"dú","meaning":"đọc","example":"她读书很快。","examplePinyin":"Tā dúshū hěn kuài.","exampleMeaning":"Cô ấy đọc sách rất nhanh."},{"word":"对不起","pinyin":"duìbùqǐ","meaning":"xin lỗi","example":"对不起，我迟到了。","examplePinyin":"Duìbuqǐ, wǒ chídào le.","exampleMeaning":"Xin lỗi, tôi đến muộn."},{"word":"多","pinyin":"duō","meaning":"nhiều","example":"我有很多书。","examplePinyin":"Wǒ yǒu hěn duō shū.","exampleMeaning":"Tôi có nhiều sách."},{"word":"多少","pinyin":"duōshǎo","meaning":"bao nhiêu","example":"这本书多少钱？","examplePinyin":"Zhè běn shū duōshǎo qián?","exampleMeaning":"Quyển sách này bao nhiêu tiền?"},{"word":"儿子","pinyin":"érzi","meaning":"con trai","example":"我的儿子很聪明。","examplePinyin":"Wǒ de érzi hěn cōngmíng.","exampleMeaning":"Con trai của tôi rất thông minh."},{"word":"二","pinyin":"èr","meaning":"hai/ 2","example":"我喜欢“二”数字。","examplePinyin":"Wǒ xǐhuān \"èr\" shùzi","exampleMeaning":"Tôi thích số 2."},{"word":"饭馆","pinyin":"fànguǎn","meaning":"nhà hàng/quán ăn","example":"我们去饭馆吃饭。","examplePinyin":"Wǒmen qù fànguǎn chīfàn.","exampleMeaning":"Chúng tôi đi nhà hàng ăn cơm."},{"word":"飞机","pinyin":"fēijī","meaning":"máy bay","example":"飞机很快。","examplePinyin":"Fēijī hěn kuài.","exampleMeaning":"Máy bay thì nhanh."},{"word":"分钟","pinyin":"fēnzhōng","meaning":"phút","example":"他等了五分钟。","examplePinyin":"Tā děngle wǔ fēnzhōng.","exampleMeaning":"Anh ấy đợi năm phút."},{"word":"高兴","pinyin":"gāoxìng","meaning":"vui","example":"我很高兴。","examplePinyin":"Wǒ hěn gāoxìng.","exampleMeaning":"Tôi rất vui."},{"word":"个","pinyin":"gè","meaning":"cái (đơn vị lượng từ)","example":"我有一个钱包。","examplePinyin":"Wǒ yǒu yī ge qiánbāo.","exampleMeaning":"Tôi có một cái ví tiền."},{"word":"工作","pinyin":"gōngzuò","meaning":"công việc","example":"我的工作很忙。","examplePinyin":"Wǒ de gōngzuò hěn máng.","exampleMeaning":"Công việc của tôi rất bận."},{"word":"狗","pinyin":"gǒu","meaning":"chó","example":"这只狗很可爱。","examplePinyin":"Zhè zhī gǒu hěn kě'ài.","exampleMeaning":"Con chó này rất dễ thương."},{"word":"汉语","pinyin":"Hànyǔ","meaning":"tiếng Hán","example":"我在学汉语。","examplePinyin":"Wǒ zài xué Hànyǔ.","exampleMeaning":"Tôi đang học tiếng Trung."},{"word":"好","pinyin":"hǎo","meaning":"tốt, khỏe","example":"他很好。","examplePinyin":"Tā hěn hǎo.","exampleMeaning":"Anh ấy rất tốt."},{"word":"喝","pinyin":"hē","meaning":"uống","example":"我喝水。","examplePinyin":"Wǒ hē shuǐ.","exampleMeaning":"Tôi uống nước."},{"word":"和","pinyin":"hé","meaning":"và","example":"我和你一起去。","examplePinyin":"Wǒ hé nǐ yīqǐ qù.","exampleMeaning":"Tôi và bạn cùng đi."},{"word":"很","pinyin":"hěn","meaning":"rất","example":"这个苹果很甜。","examplePinyin":"Zhège píngguǒ hěn tián.","exampleMeaning":"Cái táo này rất ngọt."},{"word":"后面","pinyin":"hòumiàn","meaning":"phía sau","example":"我家在后面。","examplePinyin":"Wǒ jiā zài hòumiàn.","exampleMeaning":"Nhà tôi ở phía sau."},{"word":"回","pinyin":"huí","meaning":"quay lại, về","example":"我回家了。","examplePinyin":"Wǒ huí jiā le.","exampleMeaning":"Tôi đã về nhà."},{"word":"会","pinyin":"huì","meaning":"sẽ, biết (kỹ năng)","example":"我会说汉语。","examplePinyin":"Wǒ huì shuō Hànyǔ.","exampleMeaning":"Tôi biết nói tiếng Trung."},{"word":"火车站","pinyin":"huǒchēzhàn","meaning":"ga tàu","example":"火车站在前面。","examplePinyin":"Huǒchēzhàn zài qiánmiàn.","exampleMeaning":"Ga tàu ở phía trước."},{"word":"几","pinyin":"jǐ","meaning":"mấy","example":"你有几个苹果？","examplePinyin":"Nǐ yǒu jǐ ge píngguǒ?","exampleMeaning":"Bạn có mấy quả táo?"},{"word":"家","pinyin":"jiā","meaning":"gia đình, nhà","example":"我家有四口人。","examplePinyin":"Wǒ jiā yǒu sì kǒu rén.","exampleMeaning":"Nhà tôi có bốn người."},{"word":"叫","pinyin":"jiào","meaning":"gọi, tên gọi","example":"她叫李娜。","examplePinyin":"Tā jiào Lǐ Nà.","exampleMeaning":"Cô ấy tên là Lý Na."},{"word":"今天","pinyin":"jīntiān","meaning":"hôm nay","example":"今天是星期一。","examplePinyin":"Jīntiān shì xīngqī yī.","exampleMeaning":"Hôm nay là thứ Hai."},{"word":"九","pinyin":"jiǔ","meaning":"chín/9","example":"我有九本书。","examplePinyin":"Wǒ yǒu jiǔ běn shū.","exampleMeaning":"Tôi có chín quyển sách."},{"word":"开","pinyin":"kāi","meaning":"mở, khởi động","example":"我们开车去。","examplePinyin":"Wǒmen kāichē qù.","exampleMeaning":"Chúng tôi đi bằng ô tô."},{"word":"看","pinyin":"kàn","meaning":"xem","example":"我喜欢看电影。","examplePinyin":"Wǒ xǐhuān kàn diànyǐng.","exampleMeaning":"Tôi thích xem phim."},{"word":"看见","pinyin":"kànjiàn","meaning":"nhìn thấy","example":"我看见你了。","examplePinyin":"Wǒ kànjiàn nǐ le.","exampleMeaning":"Tôi đã thấy bạn."},{"word":"块","pinyin":"kuài","meaning":"miếng/ đồng (tiền)/nhanh","example":"这个苹果两块钱。","examplePinyin":"Zhège píngguǒ liǎng kuài qián.","exampleMeaning":"Cái táo này hai tệ."},{"word":"来","pinyin":"lái","meaning":"đến","example":"明天我来。","examplePinyin":"Míngtiān wǒ lái.","exampleMeaning":"Ngày mai tôi đến."},{"word":"老师","pinyin":"lǎoshī","meaning":"giáo viên","example":"我的老师很友好。","examplePinyin":"Wǒ de lǎoshī hěn yǒuhǎo.","exampleMeaning":"Giáo viên của tôi rất thân thiện."},{"word":"了","pinyin":"le","meaning":"đã (dùng để chỉ sự thay đổi)","example":"她去了学校。","examplePinyin":"Tā qùle xuéxiào.","exampleMeaning":"Cô ấy đã đi đến trường."},{"word":"冷","pinyin":"lěng","meaning":"lạnh","example":"外面很冷。","examplePinyin":"Wàimiàn hěn lěng.","exampleMeaning":"Bên ngoài rất lạnh."},{"word":"里","pinyin":"lǐ","meaning":"trong","example":"我的书在里面。","examplePinyin":"Wǒ de shū zài lǐmiàn.","exampleMeaning":"Sách của tôi ở bên trong."},{"word":"零","pinyin":"líng","meaning":"không / 0","example":"今天零度。","examplePinyin":"Jīntiān líng dù.","exampleMeaning":"Hôm nay không độ."},{"word":"六","pinyin":"liù","meaning":"sáu/6","example":"我有六个苹果。","examplePinyin":"Wǒ yǒu liù ge píngguǒ.","exampleMeaning":"Tôi có sáu quả táo."},{"word":"妈妈","pinyin":"māma","meaning":"mẹ","example":"我的妈妈很漂亮。","examplePinyin":"Wǒ de māmā hěn piàoliang.","exampleMeaning":"Mẹ của tôi rất xinh đẹp."},{"word":"吗","pinyin":"ma","meaning":"không (dùng trong câu hỏi)","example":"你好吗？","examplePinyin":"Nǐ hǎo ma?","exampleMeaning":"Bạn khỏe không?"},{"word":"买","pinyin":"mǎi","meaning":"mua","example":"我买了水果。","examplePinyin":"Wǒ mǎile shuǐguǒ.","exampleMeaning":"Tôi đã mua trái cây."},{"word":"猫","pinyin":"māo","meaning":"mèo","example":"这只猫很可爱。","examplePinyin":"Zhè zhī māo hěn kě'ài.","exampleMeaning":"Con mèo này rất dễ thương."},{"word":"没","pinyin":"méi","meaning":"không có, chưa","example":"我没看见他。","examplePinyin":"Wǒ méi kànjiàn tā.","exampleMeaning":"Tôi không nhìn thấy anh ấy."},{"word":"没关系","pinyin":"méi guānxi","meaning":"không sao, không có gì","example":"下雨了，没关系，我们有伞。","examplePinyin":"Xiàyǔ le, méi guānxì, wǒmen yǒu sǎn.","exampleMeaning":"Trời mưa rồi, không sao đâu, chúng ta có ô."},{"word":"米饭","pinyin":"mǐfàn","meaning":"cơm","example":"我们吃米饭。","examplePinyin":"Wǒmen chī mǐfàn.","exampleMeaning":"Chúng tôi ăn cơm."},{"word":"明天","pinyin":"míngtiān","meaning":"ngày mai","example":"明天见。","examplePinyin":"Míngtiān jiàn.","exampleMeaning":"Ngày mai gặp."},{"word":"名字","pinyin":"míngzi","meaning":"tên","example":"你叫什么名字？","examplePinyin":"Nǐ jiào shénme míngzì?","exampleMeaning":"Bạn tên là gì?"},{"word":"哪里, 哪儿","pinyin":"nǎlǐ , nǎr","meaning":"đâu, chỗ nào","example":"你要去哪儿？","examplePinyin":"Nǐ yào qù nǎr？","exampleMeaning":"Bạn muốn đi đâu?"},{"word":"那","pinyin":"nà","meaning":"đó, kia","example":"那个书包很漂亮。","examplePinyin":"Nàge shūbāo hěn piàoliang.","exampleMeaning":"Cái cặp sách đó rất đẹp."},{"word":"呢","pinyin":"ne","meaning":"thì sao ? (dùng để hỏi thêm)","example":"你呢？","examplePinyin":"Nǐ ne?","exampleMeaning":"Còn bạn thì sao?"},{"word":"能","pinyin":"néng","meaning":"có thể","example":"他能说三种语言。","examplePinyin":"Tā néng shuō sān zhǒng yǔyán.","exampleMeaning":"Anh ấy có thể nói ba ngôn ngữ."},{"word":"你","pinyin":"nǐ","meaning":"bạn","example":"你叫什么名字？","examplePinyin":"Nǐ jiào shénme míngzi?","exampleMeaning":"Bạn tên là gì?"},{"word":"年","pinyin":"nián","meaning":"năm","example":"我结婚三年了。","examplePinyin":"Wǒ jiéhūn sān nián le.","exampleMeaning":"Tôi kết hôn 3 năm rồi."},{"word":"女儿","pinyin":"nǚ'ér","meaning":"con gái","example":"她是我的女儿。","examplePinyin":"Tā shì wǒ de nǚ'ér.","exampleMeaning":"Con bé là con gái của tôi."},{"word":"朋友","pinyin":"péngyou","meaning":"bạn bè","example":"她的朋友很聪明。","examplePinyin":"Tā de péngyou hěn cōngmíng.","exampleMeaning":"Bạn của cô ấy rất thông minh."},{"word":"漂亮","pinyin":"piàoliang","meaning":"đẹp","example":"她很漂亮。","examplePinyin":"Tā hěn piàoliang.","exampleMeaning":"Cô ấy rất xinh đẹp."},{"word":"苹果","pinyin":"píngguǒ","meaning":"táo","example":"这个苹果很好吃。","examplePinyin":"Zhège píngguǒ hěn hǎochī.","exampleMeaning":"Táo này rất ngon."},{"word":"七","pinyin":"qī","meaning":"bảy/7","example":"我有七个朋友。","examplePinyin":"Wǒ yǒu qī ge péngyou.","exampleMeaning":"Tôi có bảy người bạn."},{"word":"钱","pinyin":"qián","meaning":"tiền","example":"这本书多少钱？","examplePinyin":"Zhè běn shū duōshǎo qián?","exampleMeaning":"Cuốn sách này giá bao nhiêu?"},{"word":"前面","pinyin":"qiánmiàn","meaning":"phía trước","example":"火车站在前面。","examplePinyin":"Huǒchēzhàn zài qiánmiàn.","exampleMeaning":"Ga tàu ở phía trước."},{"word":"请","pinyin":"qǐng","meaning":"xin vui lòng, mời","example":"请给我菜单。","examplePinyin":"Qǐng gěi wǒ càidān.","exampleMeaning":"Xin vui lòng đưa cho tôi thực đơn."},{"word":"去","pinyin":"qù","meaning":"đi","example":"我们要去商店。","examplePinyin":"Wǒmen yào qù shāngdiàn.","exampleMeaning":"Chúng tôi phải đến cửa hàng."},{"word":"热","pinyin":"rè","meaning":"nóng","example":"天气很热。","examplePinyin":"Tiānqì hěn rè.","exampleMeaning":"Thời tiết rất nóng."},{"word":"人","pinyin":"rén","meaning":"người","example":"这个人很友好。","examplePinyin":"Zhè ge rén hěn yǒuhǎo.","exampleMeaning":"Người này rất thân thiện."},{"word":"认识","pinyin":"rènshi","meaning":"quen biết","example":"我认识他。","examplePinyin":"Wǒ rènshi tā.","exampleMeaning":"Tôi quen anh ấy."},{"word":"日","pinyin":"rì","meaning":"ngày","example":"今天是几月几日？","examplePinyin":"Jīntiān shì jǐ yuè jǐ rì?","exampleMeaning":"Hôm nay là ngày mấy tháng mấy?"},{"word":"三","pinyin":"sān","meaning":"ba/3","example":"我有三本书。","examplePinyin":"Wǒ yǒu sān běn shū.","exampleMeaning":"Tôi có ba cuốn sách."},{"word":"商店","pinyin":"shāngdiàn","meaning":"cửa hàng","example":"这个商店很大。","examplePinyin":"Zhège shāngdiàn hěn dà.","exampleMeaning":"Cửa hàng này rất lớn."},{"word":"上","pinyin":"shàng","meaning":"lên","example":"他在上楼。","examplePinyin":"Tā zài shàng lóu.","exampleMeaning":"Anh ấy đang lên tầng."},{"word":"上午","pinyin":"shàngwǔ","meaning":"buổi sáng","example":"上午我们去学校。","examplePinyin":"Shàngwǔ wǒmen qù xuéxiào.","exampleMeaning":"Vào buổi sáng chúng tôi đi học."},{"word":"少","pinyin":"shǎo","meaning":"ít","example":"我们还少一个人。","examplePinyin":"Wǒmen hái shǎo yīgè rén.","exampleMeaning":"Chúng tôi vẫn thiếu một người."},{"word":"谁","pinyin":"shuí/ shéi","meaning":"ai","example":"谁是你的老师？","examplePinyin":"Shéi shì nǐ de lǎoshī?","exampleMeaning":"Ai là giáo viên của bạn?"},{"word":"什么","pinyin":"shénme","meaning":"cái gì","example":"你想吃什么？","examplePinyin":"Nǐ xiǎng chī shénme?","exampleMeaning":"Bạn muốn ăn gì?"},{"word":"十","pinyin":"shí","meaning":"mười/10","example":"我有十块钱。","examplePinyin":"Wǒ yǒu shí kuài qián.","exampleMeaning":"Tôi có mười tệ."},{"word":"时候","pinyin":"shíhòu","meaning":"lúc, khi","example":"你什么时候来？","examplePinyin":"Nǐ shénme shíhòu lái?","exampleMeaning":"Bạn đến lúc nào ?"},{"word":"是","pinyin":"shì","meaning":"là, thì","example":"这是一本好书。","examplePinyin":"Zhè shì yī běn hǎo shū.","exampleMeaning":"Đây là một cuốn sách hay."},{"word":"书","pinyin":"shū","meaning":"sách","example":"这本书很有意思。","examplePinyin":"Zhè běn shū hěn yǒuyìsi.","exampleMeaning":"Cuốn sách này rất thú vị."},{"word":"水","pinyin":"shuǐ","meaning":"nước","example":"我喝水。","examplePinyin":"Wǒ hē shuǐ.","exampleMeaning":"Tôi uống nước."},{"word":"水果","pinyin":"shuǐguǒ","meaning":"trái cây","example":"她喜欢吃水果。","examplePinyin":"Tā xǐhuān chī shuǐguǒ.","exampleMeaning":"Cô ấy thích ăn trái cây."},{"word":"睡觉","pinyin":"shuìjiào","meaning":"ngủ","example":"他每天晚上十点睡觉。","examplePinyin":"Tā měitiān wǎnshàng shí diǎn shuìjiào.","exampleMeaning":"Anh ấy đi ngủ lúc mười giờ tối mỗi ngày."},{"word":"说话","pinyin":"shuōhuà","meaning":"nói chuyện","example":"你怎么不说话？","examplePinyin":"Nǐ zěnme bù shuōhuà?","exampleMeaning":"Sao bạn không nói chuyện thế?"},{"word":"四","pinyin":"sì","meaning":"bốn/4","example":"他们四个人去旅行。","examplePinyin":"Tāmen sì gè rén qù lǚxíng.","exampleMeaning":"Bốn người họ đi du lịch."},{"word":"岁","pinyin":"suì","meaning":"tuổi","example":"我今年二十五岁。","examplePinyin":"Wǒ jīnnián èrshíwǔ suì.","exampleMeaning":"Tôi năm nay hai mươi lăm tuổi."},{"word":"他","pinyin":"tā","meaning":"anh ấy, ông ấy","example":"他是我的朋友。","examplePinyin":"Tā shì wǒ de péngyou.","exampleMeaning":"Anh ấy là bạn của tôi."},{"word":"她","pinyin":"tā","meaning":"cô ấy, bà ấy","example":"她在家里。","examplePinyin":"Tā zài jiālǐ.","exampleMeaning":"Cô ấy ở nhà."},{"word":"太","pinyin":"tài","meaning":"quá","example":"今天太热了。","examplePinyin":"Jīntiān tài rè le.","exampleMeaning":"Hôm nay nóng quá."},{"word":"天气","pinyin":"tiānqì","meaning":"thời tiết","example":"今天天气很好。","examplePinyin":"Jīntiān tiānqì hěn hǎo.","exampleMeaning":"Thời tiết hôm nay rất tốt."},{"word":"听","pinyin":"tīng","meaning":"nghe","example":"我喜欢听音乐。","examplePinyin":"Wǒ xǐhuān tīng yīnyuè.","exampleMeaning":"Tôi thích nghe nhạc."},{"word":"同学","pinyin":"tóngxué","meaning":"bạn học","example":"我们是同学。","examplePinyin":"Wǒmen shì tóngxué.","exampleMeaning":"Chúng tôi là bạn học."},{"word":"喂","pinyin":"wèi","meaning":"alo","example":"喂，你好吗？","examplePinyin":"Wèi, nǐ hǎo ma?","exampleMeaning":"Alo, bạn khỏe không?"},{"word":"我","pinyin":"wǒ","meaning":"tôi","example":"我想喝水。","examplePinyin":"Wǒ xiǎng hē shuǐ.","exampleMeaning":"Tôi muốn uống nước."},{"word":"我们","pinyin":"wǒmen","meaning":"chúng tôi","example":"我们一起去吧。","examplePinyin":"Wǒmen yīqǐ qù ba.","exampleMeaning":"Chúng ta cùng đi nhé."},{"word":"五","pinyin":"wǔ","meaning":"năm / 5","example":"他有五本书。","examplePinyin":"Tā yǒu wǔ běn shū.","exampleMeaning":"Anh ấy có năm cuốn sách."},{"word":"喜欢","pinyin":"xǐhuān","meaning":"thích","example":"我喜欢喝咖啡。","examplePinyin":"Wǒ xǐhuān hē kāfēi.","exampleMeaning":"Tôi thích uống cà phê."},{"word":"下","pinyin":"xià","meaning":"xuống/dưới","example":"我在下楼。","examplePinyin":"Wǒ zài xià lóu.","exampleMeaning":"Tôi đang xuống lầu."},{"word":"下午","pinyin":"xiàwǔ","meaning":"buổi chiều","example":"下午我们去逛街。","examplePinyin":"Xiàwǔ wǒmen qù guàngjiē.","exampleMeaning":"uổi chiều, chúng tôi đi dạo phố."},{"word":"下雨","pinyin":"xià yǔ","meaning":"mưa","example":"外面下雨了，记得带伞。","examplePinyin":"Wàimiàn xià yǔ le, jìdé dài sǎn.","exampleMeaning":"Ngoài trời mưa, nhớ mang theo ô."},{"word":"先生","pinyin":"xiānshēng","meaning":"Tiên sinh","example":"先生，这边请。","examplePinyin":"Xiānshēng, zhè biān qǐng","exampleMeaning":"Mời anh qua bên này."},{"word":"现在","pinyin":"xiànzài","meaning":"bây giờ","example":"我现在很累。","examplePinyin":"Wǒ xiànzài hěn lèi.","exampleMeaning":"Tôi hiện tại rất mệt."},{"word":"想","pinyin":"xiǎng","meaning":"nghĩ, muốn","example":"我想去看电影。","examplePinyin":"Wǒ xiǎng qù kàn diànyǐng.","exampleMeaning":"Tôi muốn đi xem phim."},{"word":"小","pinyin":"xiǎo","meaning":"nhỏ","example":"这是一只小狗。","examplePinyin":"Zhè shì yī zhī xiǎo gǒu.","exampleMeaning":"Đây là một chú chó con."},{"word":"小姐","pinyin":"xiǎojiě","meaning":"cô (trong cách gọi)","example":"小姐，请问这里有洗手间吗？","examplePinyin":"Xiǎojiě, qǐngwèn zhèlǐ yǒu xǐshǒujiān ma?","exampleMeaning":"Cô ơi, xin hỏi ở đây có nhà vệ sinh không?"},{"word":"些","pinyin":"xiē","meaning":"vài","example":"我们买了一些水果。","examplePinyin":"Wǒmen mǎile yīxiē shuǐguǒ.","exampleMeaning":"Chúng tôi đã mua một ít trái cây."},{"word":"写","pinyin":"xiě","meaning":"viết","example":"我正在写信。","examplePinyin":"Wǒ zhèngzài xiě xìn.","exampleMeaning":"Tôi đang viết thư."},{"word":"谢谢","pinyin":"xièxiè","meaning":"cảm ơn","example":"谢谢你的帮助。","examplePinyin":"Xièxiè nǐ de bāngzhù.","exampleMeaning":"Cảm ơn sự giúp đỡ của bạn."},{"word":"星期","pinyin":"xīngqī","meaning":"tuần","example":"一个星期就好。","examplePinyin":"Yí gè xīngqī jiǔ hǎo.","exampleMeaning":"Một tuần là được"},{"word":"学生","pinyin":"xuéshēng","meaning":"học sinh","example":"他是一个好学生。","examplePinyin":"Tā shì yīgè hǎo xuéshēng.","exampleMeaning":"Anh ấy là một học sinh giỏi."},{"word":"学习","pinyin":"xuéxí","meaning":"học tập","example":"学习中文很有趣。","examplePinyin":"Xuéxí zhōngwén hěn yǒuqù.","exampleMeaning":"Học tiếng Trung rất thú vị."},{"word":"学校","pinyin":"xuéxiào","meaning":"trường học","example":"我在学校学习中文。","examplePinyin":"Wǒ zài xuéxiào xuéxí zhōngwén.","exampleMeaning":"Tôi học tiếng Trung ở trường."},{"word":"一","pinyin":"yī","meaning":"một / 1","example":"一个人在公园散步。","examplePinyin":"Yī gè rén zài gōngyuán sànbù.","exampleMeaning":"Một người đang đi dạo trong công viên."},{"word":"衣服","pinyin":"yīfu","meaning":"quần áo","example":"这件衣服很漂亮。","examplePinyin":"Zhè jiàn yīfu hěn piàoliang.","exampleMeaning":"Bộ quần áo này rất đẹp."},{"word":"医生","pinyin":"yīshēng","meaning":"bác sĩ","example":"他是一位医生。","examplePinyin":"Tā shì yī wèi yīshēng.","exampleMeaning":"Anh ấy là một bác sĩ."},{"word":"医院","pinyin":"yīyuàn","meaning":"bệnh viện","example":"我们去医院看病。","examplePinyin":"Wǒmen qù yīyuàn kàn bìng.","exampleMeaning":"Chúng tôi đến bệnh viện để khám bệnh."},{"word":"椅子","pinyin":"yǐzi","meaning":"ghế;cái ghế","example":"请坐在椅子上。","examplePinyin":"Qǐng zuò zài yǐzi shàng.","exampleMeaning":"Xin ngồi lên ghế."},{"word":"月","pinyin":"yuè","meaning":"tháng, mặt trăng","example":"这个月我很忙。","examplePinyin":"Zhège yuè wǒ hěn máng.","exampleMeaning":"Tháng này tôi rất bận."},{"word":"在","pinyin":"zài","meaning":"ở, tại","example":"他在学校学习。","examplePinyin":"Tā zài xuéxiào xuéxí.","exampleMeaning":"Anh ấy học ở trường."},{"word":"再见","pinyin":"zàijiàn","meaning":"tạm biệt","example":"我们明天再见。","examplePinyin":"Wǒmen míngtiān zàijiàn.","exampleMeaning":"Chúng ta gặp lại vào ngày mai."},{"word":"怎么","pinyin":"zěnme","meaning":"làm sao","example":"你怎么了？","examplePinyin":"Nǐ zěnme le?","exampleMeaning":"Bạn sao vậy?"},{"word":"怎么样","pinyin":"zěnmeyàng","meaning":"như thế nào","example":"你的工作怎么样？","examplePinyin":"Nǐ de gōngzuò zěnmeyàng?","exampleMeaning":"Công việc của bạn thế nào?"},{"word":"这","pinyin":"zhè","meaning":"Đây, này","example":"这件事怎么样？","examplePinyin":"Zhè jiàn shì zěnme yàng?","exampleMeaning":"Việc này như thế nào?"},{"word":"中国","pinyin":"Zhōngguó","meaning":"Trung Quốc","example":"中国有很多美丽的风景。","examplePinyin":"Zhōngguó yǒu hěn duō měilì de fēngjǐng.","exampleMeaning":"Trung Quốc có nhiều cảnh đẹp."},{"word":"中午","pinyin":"zhōngwǔ","meaning":"buổi trưa","example":"中午我们去吃饭吧。","examplePinyin":"Zhōngwǔ wǒmen qù chīfàn ba.","exampleMeaning":"Buổi trưa chúng ta đi ăn cơm nhé."},{"word":"住","pinyin":"zhù","meaning":"sống, cư trú","example":"我住在一个很安静的地方。","examplePinyin":"Wǒ zhù zài yīgè hěn ānjìng de dìfāng.","exampleMeaning":"Tôi sống ở một nơi rất yên tĩnh."},{"word":"桌子","pinyin":"zhuōzi","meaning":"bàn","example":"桌子上放着一本书。","examplePinyin":"Zhuōzi shàng fàngzhe yī běn shū.","exampleMeaning":"Trên bàn có một cuốn sách."},{"word":"字","pinyin":"zì","meaning":"chữ","example":"我们要学会写字。","examplePinyin":"Wǒmen yào xuéhuì xiě zì.","exampleMeaning":"Chúng ta phải học viết chữ."},{"word":"昨天","pinyin":"zuótiān","meaning":"hôm qua","example":"昨天我去看了一部电影。","examplePinyin":"Zuótiān wǒ qù kànle yī bù diànyǐng.","exampleMeaning":"Hôm qua tôi đã đi xem một bộ phim."},{"word":"坐","pinyin":"zuò","meaning":"ngồi","example":"我们在公园里坐了一会儿。","examplePinyin":"Wǒmen zài gōngyuán lǐ zuòle yīhuìr.","exampleMeaning":"Chúng tôi đã ngồi một lúc trong công viên."},{"word":"做","pinyin":"zuò","meaning":"làm","example":"他正在做作业。","examplePinyin":"Tā zhèngzài zuò zuòyè.","exampleMeaning":"Anh ấy đang làm bài tập về nhà."}]}